rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow logged in users to read all user profiles, and write their own
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow logged in users to read, create, update, and delete feed posts
    match /posts/{postId} {
      allow read, create, update: if request.auth != null;
      allow delete: if request.auth != null && (resource.data.authorUid == request.auth.uid || request.auth.token.email == 'marketing@bahiaprev.com.br');

      match /comments/{commentId} {
        allow read, create, update: if request.auth != null;
        allow delete: if request.auth != null && (resource.data.authorUid == request.auth.uid || request.auth.token.email == 'marketing@bahiaprev.com.br');
      }
    }

    // Generic fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
